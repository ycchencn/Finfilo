# .env.sample 配置模板
# 数据库配置
DATABASE_CONN_STR=mysql+pymysql://sample_user:sample_password@127.0.0.1:3306/sample_database

# DeepSeek API
DEEPSEEK_APIKEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 阿里云百炼API
ALIYUN_BAILIAN_APIKEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 豆包API
DOUBAO_APIKEY=ark-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# siliconflow
SILICONFLOW_APIKEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 腾讯API
TENCENT_APIKEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 智谱API
ZHIPU_APIKEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxx

# 飞书机器人Webhook
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Redis配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# RabbitMQ配置
RABBITMQ_HOST=sample_rabbitmq_host
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=sample_user
RABBITMQ_PASSWORD=sample_password
RABBITMQ_VIRTUAL_HOST=/
RABBITMQ_QUEUE_NAME=sample_queue_name

# 缓存设置（单位：秒，非涉密保留参考值）
CACHE_STOCK_LIST=1800
CACHE_STOCK_HISTORY=3600

# 大模型配置
LLM_MODEL_QWEN=qwen3.6-plus

# 数据接口地址
DATAJIJI_HOST=https://sample-api.example.com

# ES配置
ES_HOST="http://sample_es_host:9200/"
ES_USER="sample_es_user"
ES_PASSWORD="sample_es_password"

# websocket地址
VITE_WS_URL=''